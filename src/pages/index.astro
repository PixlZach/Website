---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
		</main>
		<Footer />
		<a href="/secret" class="hidden-btn" aria-hidden="true"></a>
		<style>
			.hidden-btn {
				position: fixed;
				bottom: 1rem;
				right: 1rem;
				width: 24px;
				height: 24px;
				background: #333;
				border-radius: 4px;
				text-decoration: none;
				display: block;
			}
			.hidden-btn:hover {
				background: #555;
			}
		</style>
	</body>
</html>
